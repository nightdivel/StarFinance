# Star Finance Backend Environment Configuration
# Copy this file to .env and fill in the actual values for your environment

# === Database Configuration ===
# PostgreSQL connection settings (either use individual PG_* vars or DATABASE_URL)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=starfinance
PG_USER=postgres
PG_PASSWORD=postgres
# Alternative: DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starfinance
# PG_SSL=false

# === Node Environment ===
NODE_ENV=development
PORT=3000

# === Frontend URL (for CORS and redirects) ===
FRONTEND_URL=http://localhost:5173

# === Discord OAuth Configuration ===
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
DISCORD_BOT_TOKEN=your_discord_bot_token

# === Tools Section Configuration ===
# These environment variables are used by the Tools section for executing actions

# REST API Calls - Bearer token for authentication when action_type=rest_call
# Used in Authorization header: Bearer {{TOOLS_API_TOKEN}}
# Keep this secret and never commit to version control
TOOLS_API_TOKEN=your_rest_api_bearer_token

# Telegram Bot Token - for sending messages via Telegram when action_type=telegram_send
# Get this from BotFather on Telegram: https://t.me/BotFather
# Keep this secret and never commit to version control
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# Discord Tools Webhook URL - for sending messages to Discord when action_type=discord_send
# Create this webhook in Discord: Server Settings → Integrations → Webhooks → New Webhook
# Keep this secret and never commit to version control
DISCORD_TOOLS_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Tool Icon Upload Directory - where tool icons are stored on the filesystem
# Default: /public/uploads/tools (relative to backend directory)
TOOL_ICON_UPLOAD_DIR=/public/uploads/tools

# === App Data Cache TTL (milliseconds) ===
APP_DATA_CACHE_TTL_MS=2000

# === Logging Configuration (optional) ===
LOG_LEVEL=info
