# Домен и почта для Caddy / Let's Encrypt
DOMAIN=fin.blacksky.su
EMAIL=you@example.com
CERT_NAME=fin.blacksky.su

# Внешний URL фронта (приложение публикуется под /economy)
FRONTEND_URL=https://fin.blacksky.su/economy
DISCORD_REDIRECT_URI=https://fin.blacksky.su/economy/auth/discord/callback
DISCORD_BOT_TOKEN=

# Настройки PostgreSQL (должны совпадать с docker-compose.yml)
PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=starfinance
PG_USER=postgres
PG_PASSWORD=postgres

# При необходимости добавь сюда остальные секреты
# например, DISCORD_CLIENT_ID, DISCORD_CLIENT_SECRET и т.п.
